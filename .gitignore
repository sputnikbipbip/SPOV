## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This list is a standard C# / .NET gitignore template.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache directories and files
.vs/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (DotSettings)
*.csproj.DotSettings.user

# Roslyn cache directories
*.Selector-*.txt

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackage[Ss]/
# except build/, which is used as an MSBuild target.
!**/[Pp]ackage[Ss]/build/
# Uncomment if using NuGet repositories to store project specific packages (not recommended)
# !**/[Pp]ackage[Ss]/

# Microsoft Azure Build Output
csx/
*.build.csdef

# Microsoft Azure Emulator
ecf/
rcf/

# Windows Azure Project Build Output
CanvasBuild/

# Node.js
node_modules/
dist/
.angular/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# JetBrains Rider
.idea/
*.sln.iml
riderModule.iml

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper.user

# VS Code
.vscode/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# User-specific appsettings (keep the main ones, ignore the secrets)
appsettings.json
appsettings.Local.json
*.user.json

# Environment variables
.env
.env.*
!.env.example

# Docker secrets (plaintext passwords)
docker/secrets/

# Custom ignore for study materials
BUILD_ARTIFACTS.md

# Junie memory files
.junie/memory/
